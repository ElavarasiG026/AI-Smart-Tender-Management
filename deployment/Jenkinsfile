pipeline {
    agent any

    environment {
        REGISTRY = 'docker.io'
        IMAGE_TAG = 'latest'
        GITHUB_REPO = 'github.com/yourusername/AI-Smart-Tender-Management.git'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: "https://${GITHUB_REPO}"
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh '''
                        npm install
                        npm run build
                        npm test || true
                    '''
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh '''
                        npm install
                        npm run build
                    '''
                }
            }
        }

        stage('Build AI Service') {
            steps {
                dir('ai-service') {
                    sh '''
                        pip install -r requirements.txt
                        python -m pytest tests/ || true
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                    docker-compose build
                '''
            }
        }

        stage('Docker Push') {
            steps {
                sh '''
                    docker tag tender-backend:latest ${REGISTRY}/yourusername/tender-backend:${IMAGE_TAG}
                    docker tag tender-frontend:latest ${REGISTRY}/yourusername/tender-frontend:${IMAGE_TAG}
                    docker tag tender-ai-service:latest ${REGISTRY}/yourusername/tender-ai-service:${IMAGE_TAG}
                    
                    docker push ${REGISTRY}/yourusername/tender-backend:${IMAGE_TAG}
                    docker push ${REGISTRY}/yourusername/tender-frontend:${IMAGE_TAG}
                    docker push ${REGISTRY}/yourusername/tender-ai-service:${IMAGE_TAG}
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    docker-compose down || true
                    docker-compose up -d
                    sleep 10
                    curl http://localhost:3000/api/health
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                    #!/bin/bash
                    for i in {1..10}; do
                        if curl -f http://localhost:3000/api/health; then
                            echo "Backend is healthy"
                            break
                        fi
                        echo "Attempt $i: Waiting for backend..."
                        sleep 5
                    done
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Pipeline succeeded!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
